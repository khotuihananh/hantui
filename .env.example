# Sao chép file này thành .env.local rồi điền khóa từ Supabase.
# Lấy tại: Supabase Dashboard -> Project Settings -> API

# URL project (dạng https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Khóa công khai anon (Project API keys -> anon public) - dùng để ĐỌC dữ liệu
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Khóa service role (Project API keys -> service_role) - CHỈ dùng phía server.
# TUYỆT ĐỐI KHÔNG chia sẻ khóa này công khai.
SUPABASE_SERVICE_ROLE_KEY=

# Mật khẩu đăng nhập trang admin (tự đặt, dùng để vào /admin)
ADMIN_PASSWORD=
